#!/usr/bin/env bash
# multica-flow â€” drive a ticket through the exploreâ†’workâ†’reviewâ†’qaâ†’learn pipeline.
#
# Subcommands:
#   bootstrap                  Create the 5 role agents (one per phase) for your tool.
#   new <title> [--tool ...]   Create a ticket in phase:explore and dispatch.
#   next <id>                  Advance a ticket to the next phase (manual override).
#   rewind <id> [--reason X]   Send a ticket back to phase:work.
#   status <id>                Show phase, state, last comment.
#   ls [--phase X]             List tickets currently in a phase.
#
# Reads ~/.multica-skill/workflow.yaml for the role-agent slugs (with sensible
# defaults if absent). The yaml is plain key=value pairs to avoid a YAML dep.
set -euo pipefail

CONFIG_FILE="${MULTICA_FLOW_CONFIG:-${HOME}/.multica-skill/workflow.yaml}"

# --- Tiny "yaml" reader (key: value, one per line, # comments) --------------
cfg_get() {
  local key="$1" default="$2"
  if [[ -f "$CONFIG_FILE" ]]; then
    local val
    val=$(awk -F': *' -v k="$key" '$1==k {sub(/^[^:]*: */,""); print; exit}' "$CONFIG_FILE")
    if [[ -n "$val" ]]; then echo "$val"; return; fi
  fi
  echo "$default"
}

TOOL=$(cfg_get "tool" "claude-code")
AGENT_EXPLORER=$(cfg_get  "agent_explorer"    "${TOOL}-explorer")
AGENT_IMPLEMENTER=$(cfg_get "agent_implementer" "${TOOL}-implementer")
AGENT_REVIEWER=$(cfg_get  "agent_reviewer"    "${TOOL}-reviewer")
AGENT_QA=$(cfg_get        "agent_qa"          "${TOOL}-qa")
AGENT_LEARNER=$(cfg_get   "agent_learner"     "${TOOL}-learner")

ensure_multica() {
  command -v multica >/dev/null 2>&1 || { echo "multica CLI not on PATH" >&2; exit 2; }
}

# --- bootstrap --------------------------------------------------------------
cmd_bootstrap() {
  ensure_multica
  echo "Creating role agents for tool=$TOOL â€¦"
  local script_dir
  script_dir="$(cd "$(dirname "$0")/.." && pwd)/skills/multica-workflow/lanes"

  create_or_update_agent() {
    local slug="$1" lane_file="$2"
    local sys
    sys=$(cat "${script_dir}/${lane_file}")
    if multica agent list 2>/dev/null | grep -q "$slug"; then
      multica agent update "$slug" --system-instructions "$sys" >/dev/null
      echo "  updated $slug"
    else
      multica agent create --slug "$slug" --tool "$TOOL" --system-instructions "$sys" >/dev/null
      echo "  created $slug"
    fi
  }

  create_or_update_agent "$AGENT_EXPLORER"     "01-explore.md"
  create_or_update_agent "$AGENT_IMPLEMENTER"  "02-work.md"
  create_or_update_agent "$AGENT_REVIEWER"     "03-review.md"
  create_or_update_agent "$AGENT_QA"           "04-qa.md"
  create_or_update_agent "$AGENT_LEARNER"      "05-learn.md"
  echo "Bootstrap done."
}

# --- new --------------------------------------------------------------------
cmd_new() {
  ensure_multica
  local title="${1:-}"
  [[ -z "$title" ]] && { echo "Usage: multica-flow new <title>" >&2; exit 2; }
  shift || true

  local out
  out=$(multica issue create --title "$title" --label phase:explore "$@" 2>&1)
  echo "$out"
  local id
  id=$(echo "$out" | grep -oE '[A-Z]+-[0-9]+' | head -1)
  if [[ -z "$id" ]]; then
    echo "Could not parse issue id from create output." >&2
    exit 1
  fi
  multica issue assign "$id" --agent "$AGENT_EXPLORER"
  echo "â†’ $id dispatched to $AGENT_EXPLORER"
}

# --- next -------------------------------------------------------------------
# Best-effort: read current phase label, swap to next, reassign.
cmd_next() {
  ensure_multica
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: multica-flow next <id>" >&2; exit 2; }

  local current next state agent
  current=$(multica issue get "$id" 2>&1 | grep -oE 'phase:[a-z]+' | tail -1 || true)
  case "$current" in
    phase:explore) next=phase:work    ; state=in_progress ; agent="$AGENT_IMPLEMENTER" ;;
    phase:work)    next=phase:review  ; state=in_review   ; agent="$AGENT_REVIEWER" ;;
    phase:review)  next=phase:qa      ; state=in_review   ; agent="$AGENT_QA" ;;
    phase:qa)      next=phase:learn   ; state=in_review   ; agent="$AGENT_LEARNER" ;;
    phase:learn)   next=""            ; state=done        ; agent="" ;;
    *) echo "No phase label on $id (saw: '$current'). Set one explicitly." >&2; exit 2 ;;
  esac

  if [[ -n "$next" ]]; then
    multica issue label "$id" --remove "$current" --add "$next"
  else
    multica issue label "$id" --remove "$current"
  fi
  multica issue status "$id" --set "$state"
  if [[ -n "$agent" ]]; then
    multica issue assign "$id" --agent "$agent"
  fi
  echo "â†’ $id moved: $current â†’ ${next:-DONE} (state=$state)"
}

# --- rewind -----------------------------------------------------------------
cmd_rewind() {
  ensure_multica
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: multica-flow rewind <id> [--reason X]" >&2; exit 2; }
  shift
  local reason=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) reason="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  local current
  current=$(multica issue get "$id" 2>&1 | grep -oE 'phase:[a-z]+' | tail -1 || true)
  if [[ -n "$current" && "$current" != "phase:work" ]]; then
    multica issue label "$id" --remove "$current" --add phase:work
  fi
  multica issue status "$id" --set in_progress
  multica issue assign "$id" --agent "$AGENT_IMPLEMENTER"
  multica issue comment "$id" "rewind to phase:work${reason:+ (reason: $reason)}"
  echo "â†’ $id rewound to phase:work"
}

# --- status -----------------------------------------------------------------
cmd_status() {
  ensure_multica
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: multica-flow status <id>" >&2; exit 2; }
  multica issue get "$id"
}

# --- ls ---------------------------------------------------------------------
cmd_ls() {
  ensure_multica
  local phase=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --phase) phase="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [[ -n "$phase" ]]; then
    multica issue list --label "phase:${phase#phase:}"
  else
    multica issue list
  fi
}

# --- dispatch ---------------------------------------------------------------
sub="${1:-}"
shift || true
case "$sub" in
  bootstrap)   cmd_bootstrap "$@" ;;
  new)         cmd_new "$@" ;;
  next)        cmd_next "$@" ;;
  rewind)      cmd_rewind "$@" ;;
  status)      cmd_status "$@" ;;
  ls|list)     cmd_ls "$@" ;;
  ""|-h|--help|help)
    sed -n '/^# multica-flow/,/^# Reads/p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *) echo "Unknown subcommand: $sub" >&2; exit 2 ;;
esac
